{
  "manifest_version": 3,
  "name": "A2A Web Agent",
  "version": "0.1",
  "description": "Browser extension to communicate with A2A agent server",
  "permissions": ["storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
